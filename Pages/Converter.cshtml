@page "/{from:regex(^[a-zA-Z]{{3}}$)}/{to:regex(^[a-zA-Z]{{3}}$)}/{amount:decimal}"
@model ConverterModel
@{
    Layout = null;
    ViewData["Title"] = $"FX Converter";
}

<head>
    <!-- These tags are injected directly by the C# code-behind -->
    <meta property="og:title" content="FX Converter" />
    <meta property="og:description" content="@Model.OgDescription" />
    <meta property="og:image" content="@Model.OgImage" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1040" />
    <meta property="og:image:height" content="320" />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- CSS -->
    <style>
        body { font-family: -apple-system, sans-serif; background: #0d1117; color: #c9d1d9; display: flex; justify-content: center; align-items: center; height: 100vh; }
        .box { background: #161b22; padding: 2rem; border-radius: 12px; width: 300px; text-align: center; }
        input { width: 100%; padding: 1rem; font-size: 1.5rem; background: #0d1117; border: 1px solid #30363d; color: #fff; text-align: center; }
        .val { font-size: 2.5rem; font-weight: bold; color: #58a6ff; margin: 1rem 0; }
        .info { font-size: 0.8rem; color: #8b949e; }
    </style>
</head>

<body>
    <div class="box">
        <h2>FX</h2>
        <!-- The initial value comes from the Server (Cached) -->
        <input type="number" id="amount" value="@Model.Amount.ToString(System.Globalization.CultureInfo.InvariantCulture)" oninput="updateRate(this.value)">
        <div class="val" id="result">@(Model.HasError ? "Unavailable" : Model.ResultValue)</div>
        <div class="info">@(Model.HasError ? "Could not fetch rate" : $"Updated: {Model.RateDate}")</div>
    </div>

    <!-- Client-side JS to handle the interactivity -->
    <script>
        const from = '@Model.From';
        const to = '@Model.To';
        const locale = '@Model.CultureTag' || undefined;

        async function updateRate(val) {
            const resEl = document.getElementById('result');
            resEl.textContent = "....";
            try {
                // Fetch the rate from our local Minimal API endpoint (which reads from cache)
                const response = await fetch(`/api/rate/${from}/${to}`);
                const data = await response.json();
                const converted = val * data.rate;
                resEl.textContent = converted.toLocaleString(locale, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' ' + to;
            } catch (e) {
                resEl.textContent = "Error";
            }
        }
    </script>
</body>